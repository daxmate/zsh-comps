#compdef tmux

# tmux <http://tmux.github.io> completion for zsh <http://zsh.sf.net>.
#
# Configuration:
#
# - On some OSs, the directory for tmux's server sockets may not be
#   the default (which is /tmp/tmux-<uid>/), but say
#   /var/run/tmux/tmux-<uid>, in which case the completion for
#   'tmux -L <tab>' will not be able to find the sockets in the default
#   location (debian does this, for instance); tell _tmux the right place
#   to look:
#       % zstyle ':completion:*:*:tmux:*:sockets' socketdir "/var/run/tmux/tmux-${UID}"
#
# - tmux knows a *lot* of sub-commands, hence 'tmux <tab>' returns a lot
#   of possible completions. _tmux knows about all commands and their aliases.
#   By default, both are offered. If you do not care about the aliases, do this:
#       % zstyle ':completion:*:*:tmux:*:subcommands' mode 'commands'
#
#   The same can be done to only return aliases by setting the above style
#   to 'aliases'. The default value is 'both' (but actually every value
#   different from 'commands' and 'aliases' will have the same effect).
#
#   'lsw' is an alias for 'list-windows' for example; note that not all
#   commands have aliases. So probably, either the default 'both' or
#   'commands' makes most sense for this style.
#
# - For finer grained control over what is suggested as possible completions,
#   the 'ignored-patterns' style may be used; suppose you think that only
#   '*-window' or '*-windows' are worth being completed. You would get that
#   behaviour like this:
#       % zstyle ':completion:*:*:tmux:*:subcommands' ignored-patterns '^*-window(|s)'
#
#   Some tmux commands currently do not work if called from a shell prompt,
#   so it would make sense to ignore them per default (at the time of writing,
#   those commands are choose-{session,client,window}, confirm-before and
#   find-window. This would ignore them:
#       % zstyle ':completion:*:*:tmux:*:subcommands' ignored-patterns \
#                'choose-*' 'confirm-before' 'find-window'
#
# The configuration for subcommand completions may be done in
# this context: ':completion:*:*:tmux-<sub-command>:*:*'
#
# TODO:
#
#   - Implement __tmux-style (possibly using existing helpers like
#     __tmux-attributes and __tmux-colours)
#   - in _tmux-list-panes, use __tmux-windows or __tmux-sessions
#     depending on -s is among the sub-commands current command line.

# Global variables; setup the first time _tmux is called.
# For $_tmux_commands[] generation, see the very end of this file.
typeset -ga _tmux_commands=() _tmux_aliases=()
typeset -gA _tmux_aliasmap

_tmux_aliasmap=(
    # clients and sessions
    attach      attach-session
    detach      detach-client
    has         has-session
    lockc       lock-client
    locks       lock-session
    lsc         list-clients
    lscm        list-commands
    ls          list-sessions
    new         new-session
    refresh     refresh-client
    rename      rename-session
    showmsgs    show-messages
    source      source-file
    start       start-server
    suspendc    suspend-client
    switchc     switch-client

    # windows and panes
    breakp      break-pane
    capturep    capture-pane
    displayp    display-panes
    findw       find-window
    joinp       join-pane
    killp       kill-pane
    killw       kill-window
    last        last-window
    lastp       last-pane
    linkw       link-window
    lsp         list-panes
    lsw         list-windows
    movep       move-pane
    movew       move-window
    neww        new-window
    nextl       next-layout
    next        next-window
    pipep       pipe-pane
    prev        previous-window
    prevl       previous-layout
    renamew     rename-window
    resizep     resize-pane
    resizew     resize-window
    respawnp    respawn-pane
    respawnw    respawn-window
    rotatew     rotate-window
    selectl     select-layout
    selectp     select-pane
    selectw     select-window
    splitw      split-window
    swapp       swap-pane
    swapw       swap-window
    unlinkw     unlink-window

    # key bindings
    bind        bind-key
    lsk         list-keys
    send        send-keys
    unbind      unbind-key

    # options
    set         set-option
    setw        set-window-option
    show        show-options
    showw       show-window-options

    # environment
    setenv      set-environment
    showenv     show-environment

    # status line
    confirm     confirm-before
    menu        display-menu
    display     display-message
    popup       display-popup

    # buffers
    clearhist   clear-history
    deleteb     delete-buffer
    lsb         list-buffers
    loadb       load-buffer
    pasteb      paste-buffer
    saveb       save-buffer
    setb        set-buffer
    showb       show-buffer

    # miscellaneous
    if          if-shell
    lock        lock-server
    run         run-shell
    info        server-info
    wait        wait-for
)

# --- Sub-command functions ---
# These *must* be called _tmux-*(); The description generation relies on
# them being named that way. *No* other functions may match that pattern.
# Other utility functions should be named __tmux-*() (see below).
#
# Another thing, the description generation needs, is handling of
# $tmux_describe: If that parameter is non-empty, the sub-command function
# should only print a description of the sub-command it handles and return
# immediately after doing so.
#
# To add support for a new sub-command, you only have to add a new
# _tmux-<foo>() function below (preferably alphabetically sorted), that
# behaves like described above; and add a alias->command pair in the
# _tmux_aliasmap associative array above (if the command in fact has an
# alias). The rest should just work[tm].

_tmux-attach-session() {
  [[ -n ${tmux_describe} ]] && print "附加或切换到会话" && return

  _arguments -s \
    '-c+[指定会话的工作目录]:directory:_directories' \
    '-d[分离目标会话的其他客户端]' \
    '-f+[设置客户端标志]: :_tmux_client_flags' \
    '-r[将客户端置于只读模式]' \
    '-t+[指定目标会话]:target session: __tmux-sessions-separately' \
    "-E[不应用 update-environment 选项]" \
    '-x[使用 -d，向连接客户端的父进程发送 SIGHUP]'
}

_tmux-bind-key() {
  [[ -n ${tmux_describe} ]] && print "将按键绑定到命令" && return
  _arguments -s -A "-*" \
    '-n[使绑定无需前缀键即可工作]' \
    '-r[按键可重复]' \
    '-N+[为按键附加备注]:note' \
    '-T+[指定绑定的键表]:key table' \
    '1:key' \
    '*:::template:= _tmux'
}

_tmux-break-pane() {
  [[ -n ${tmux_describe} ]] && print "将面板从现有窗口拆分为新窗口" && return
  _arguments -s \
    '(-b)-a[将窗口移动到下一个索引之后]' \
    '(-a)-b[将窗口移动到下一个索引之前]' \
    "-d[不使新窗口成为活动窗口]" \
    '-F+[指定输出格式]:format:__tmux-formats' \
    '-P[创建后打印新窗口的信息]' \
    '-n+[指定窗口名称]:name' \
    '-s+[指定源窗格]:pane:__tmux-panes' \
    '-t+[指定目标窗口]:pane:__tmux-panes'
}

_tmux-capture-pane() {
  [[ -n ${tmux_describe} ]] && print "捕获面板内容到缓冲区" && return
  _arguments -s \
    '-a[使用备用屏幕]' \
    '(-p)-b+[选择目标缓冲区]:target buffer:__tmux-buffers' \
    '-C[将非打印字符转义为八进制 \\ooo]' \
    '-e[包含属性等的转义序列]' \
    '-E[指定要捕获的最后一行]:line number (- means last line)' \
    '(-N)-J[连接换行行并保留尾部空格]' \
    '(-J)-N[保留尾部空格]' \
    '-q[尝试访问备用屏幕时忽略错误]' \
    '(-b)-p[将数据打印到 stdout]' \
    '-P[仅捕获尚未完成的转义序列的开头]' \
    '-S[指定捕获起始行]:first line (- means start of scrollback)' \
    '-t+[选择源面板]:source pane:__tmux-panes'
}

_tmux-choose-buffer() {
  [[ -n ${tmux_describe} ]] && print "将面板置于缓冲区选择模式" && return
  _arguments -s \
    '-N[启动时不显示预览]' \
    '-Z[放大窗格]' \
    '-r[反转排序顺序]' \
    '-F+[指定每个列表项的格式]:format:__tmux-formats' \
    '-f+[过滤项目]:filter format:__tmux-formats' \
    '-K+[指定每个快捷键的格式]:format:__tmux-formats' \
    '-O+[初始排序顺序]:order:(time name size)' \
    '-t+[指定目标窗口]:session:__tmux-windows' \
    '*:::template:= _tmux'
}

_tmux-choose-client() {
  [[ -n ${tmux_describe} ]] && print "将窗口置于客户端选择模式" && return
  _arguments -s \
    '-N[启动时不显示预览]' \
    '-Z[放大窗格]' \
    '-r[反转排序顺序]' \
    '-F+[指定每个列表项的格式]:format:__tmux-formats' \
    '-f+[过滤项目]:filter format:__tmux-formats' \
    '-K+[指定每个快捷键的格式]:format:__tmux-formats' \
    '-O+[初始排序顺序]:order:(time name size)' \
    '-t+[指定目标窗口]:session:__tmux-windows' \
    '*:::template:= _tmux'
}

_tmux-choose-tree() {
  [[ -n ${tmux_describe} ]] && print "将窗口置于树状选择模式" && return
  _arguments -s \
    '-G[在树中包含任何会话组中的所有会话，而不仅仅是第一个]' \
    '-N[启动时不显示预览]' \
    '-Z[放大窗格]' \
    '-r[反转排序顺序]' \
    '-F+[指定每个列表项的格式]:format:__tmux-formats' \
    '-f+[过滤项目]:filter format:__tmux-formats' \
    '-K+[指定每个快捷键的格式]:format:__tmux-formats' \
    '-O+[初始排序顺序]:order:(time name size)' \
    '-s[在会话中选择]' \
    '-t+[指定目标窗口]:session:__tmux-windows' \
    '-w[在窗口中选择]' \
    '*:::template:= _tmux'
}

_tmux-clear-history() {
  [[ -n ${tmux_describe} ]] && print "移除并清除面板的历史记录" && return
  _arguments '-t+[指定目标窗格]:pane:__tmux-panes'
}

_tmux-clock-mode() {
  [[ -n ${tmux_describe} ]] && print "进入时钟模式" && return
  _arguments '-t+[指定目标窗格]:pane:__tmux-panes'
}

_tmux-command-prompt() {
  [[ -n ${tmux_describe} ]] && print "在客户端中打开 tmux 命令提示符" && return
  _arguments -s \
    '-1[仅接受一次按键]' \
    '-k[仅接受一次按键并将其转换为键名]' \
    '-N[仅接受数字按键]' \
    '-i[每次提示输入改变时执行命令]' \
    '-I+[指定初始输入列表]:initial-text (comma-separated list)' \
    '-p+[指定提示列表]:prompts (comma-separated list)' \
    '-t+[指定目标客户端]:client:__tmux-clients' \
    '(-W)-T[提示用于目标 - 按需 Tab 补全]' \
    '(-T)-W[提示用于窗口 - 按需 Tab 补全]' \
    '*:::template:= _tmux'
}

_tmux-confirm-before() {
  [[ -n ${tmux_describe} ]] && print "运行命令前请求确认" && return
  _arguments -s \
    '-p+[指定提示]:prompt string' \
    '-t+[指定目标客户端]:client:__tmux-clients' \
    '*:::command:= _tmux'
}

_tmux-copy-mode() {
  [[ -n ${tmux_describe} ]] && print "进入复制模式" && return
  _arguments -s \
    '-s+[指定源窗格]:pane:__tmux-panes' \
    '-t+[指定目标窗格]:pane:__tmux-panes' \
    '-e[滚动到底部退出 copy-mode]' \
    '-H[隐藏右上角的位置指示器]' \
    '-q[取消复制模式及其他模式]' \
    '-u[向上滚动一页]' \
    '-M[开始鼠标拖动]'
}

_tmux-customize-mode() {
  [[ -n ${tmux_describe} ]] && print "进入自定义模式" && return
  _arguments -s \
    '-F+[指定树中每个项目的格式]:format:__tmux-formats' \
    '-f+[指定初始过滤器]:filter:__tmux-formats' \
    '-N[启动时不显示选项信息]' \
    '-t+[指定目标窗格]:pane:__tmux-panes' \
    '-Z[放大窗格]'
}

_tmux-delete-buffer() {
  [[ -n ${tmux_describe} ]] && print "删除粘贴缓冲区" && return
  _arguments '-b+[指定目标缓冲区名称]:buffer:__tmux-buffers'
}

_tmux-detach-client() {
  [[ -n ${tmux_describe} ]] && print "从服务器分离客户端" && return
  _arguments -s \
    '-a[杀死除 -t 指定的客户端外的所有客户端]' \
    '-P[向父进程发送 SIGHUP]' \
    '-E+[运行指定的 shell 命令替换客户端]:shell command:_cmdstring' \
    '-s+[指定目标会话并杀死其客户端]:session:__tmux-sessions-attached' \
    '-t+[指定目标客户端]:client:__tmux-clients'
}

_tmux-display-menu() {
  [[ -n ${tmux_describe} ]] && print "显示菜单" && return
  local curcontext="$curcontext" ret=1
  local -a state line expl
  _arguments -C -s -S -A "-*" \
    '-c+[指定目标客户端]:client:__tmux-clients' \
    "-O[如果鼠标在未选择时释放则不关闭菜单]" \
    '-t+[指定目标窗格]:pane:__tmux-panes' \
    '-T+[指定标题]:title' \
    '-x+[指定水平位置]: : _alternative "columns\: \:_guard \[0-9\]\# column" "positions\:position\:((R\:right P\:bottom M\:mouse W\:window))"' \
    '-y+[指定垂直位置]: : _alternative "rows\: \:_guard \[0-9\]\# row" "positions\:position\:((P\:left M\:mouse S\:status\ line))"' \
    '*::: :->options' && ret=0

  if [[ -n $state ]]; then
    case $(( CURRENT % 3 )) in
      1) _message -e menu-options 'menu option' ;;
      2) _message -e keys 'shortcut key' ;;
      0)
	compset -q
	words=( menu "$words[@]" )
	(( CURRENT++ ))
	_tmux && ret=0
      ;;
    esac
  fi

  return ret
}

_tmux-display-message() {
  [[ -n ${tmux_describe} ]] && print "在状态栏显示消息" && return
  _arguments -s -S -A "-*" \
    '(-p -F :)-a[列出格式变量及其值]' \
    '-I[将从 stdin 读取的任何输入转发到目标窗格]' \
    '-N[忽略按键并在延迟后关闭]' \
    '-c+[指定目标客户端]:client:__tmux-clients' \
    '-d+[消息显示时间]:delay (milliseconds)' \
    '(-a)-p[将消息打印到 stdout]' \
    '-t+[指定目标窗格]:pane:__tmux-panes' \
    '(-a)-F+[指定输出格式]:format:__tmux-formats' \
    '(-a)-v[解析格式时打印详细日志]' \
    ':message:__tmux-formats'
}

_tmux-display-panes() {
  [[ -n ${tmux_describe} ]] && print "为每个可见窗格显示指示器" && return
  _arguments -S \
    "-b[不阻塞其他命令直到指示器关闭]" \
    '-d+[指示器显示时间]:duration (ms)' \
    '-t+[指定目标客户端]:client:__tmux-clients' \
    '*:::command:= _tmux'
}

_tmux-display-popup() {
  [[ -n ${tmux_describe} ]] && print "在窗格上显示弹出框" && return
  _arguments -s \
    '-C[关闭客户端上的任何弹出窗口]' \
    '-c+[指定目标客户端]:client:__tmux-clients' \
    '-d+[指定命令的工作目录]:directory:_directories' \
    '-E[命令退出时关闭弹出窗口]' \
    '-w+[指定宽度]:width' \
    '-h+[指定高度]:height' \
    '-t+[指定目标窗格]:pane:__tmux-panes' \
    '-x+[指定水平位置]:position' \
    '-y+[指定垂直位置]:position' \
    ':shell command:_cmdstring'
}

_tmux-find-window() {
  [[ -n ${tmux_describe} ]] && print "在窗口中搜索模式" && return
  _arguments -s \
    '-i[忽略大小写]' \
    '-r[使用正则表达式匹配]' \
    '-C[匹配可见内容]' \
    '-N[匹配窗口名称]' \
    '-T[匹配窗口标题]' \
    '-t+[指定目标窗口]:window:__tmux-windows' \
    '-Z[放大窗格]' \
    ':window search pattern'
}

_tmux-has-session() {
  [[ -n ${tmux_describe} ]] && print "检查并报告服务器上是否存在会话" && return
  _arguments '-t+[指定目标会话]:session:__tmux-sessions'
}

_tmux-if-shell() {
  [[ -n ${tmux_describe} ]] && print "如果 shell 命令成功则执行 tmux 命令" && return
  local curcontext="$curcontext" state line ret=1
  _arguments -C -s \
    '-b[后台运行 shell 命令]' \
    "-F[不执行 shell 命令而将其用作字符串值]" \
    '-t+[指定目标窗格]:pane:__tmux-panes' \
    '1:shell command:_cmdstring' \
    '2:tmux command (success):->tmuxcmd' \
    '3:tmux command (failure):->tmuxcmd' && ret=0
  if [[ -n $state ]]; then
    compset -q
    _tmux && ret=0
  fi
}

_tmux-join-pane() {
  [[ -n ${tmux_describe} ]] && print "拆分窗格并将现有窗格移入新空间" && return
  # -p removed from documentation but still works, or use -l and append %
  _arguments -s \
    '-b[将源窗格合并到目标窗格的左侧或上方]' \
    "-d[不使新窗口成为活动窗口]" \
    '(-l)-f[跨越全尺寸]' \
    '-h[水平拆分]' \
    '-v[垂直拆分]' \
    "(-p)-l[定义新面板大小]:size" \
    "!(-f -l)-p+:size (percentage)" \
    '-s+[指定源窗格]:pane:__tmux-panes' \
    '-t+[指定目标窗格]:pane:__tmux-panes'
}

_tmux-kill-pane() {
  [[ -n ${tmux_describe} ]] && print "销毁指定面板" && return
  _arguments -s \
    '-a[杀死除 -t 指定的窗格外的所有窗格]' \
    '-t+[指定目标窗格]:pane:__tmux-panes'
}

_tmux-kill-server() {
  [[ -n ${tmux_describe} ]] && print "杀死客户端、会话和服务器" && return
  __tmux-nothing-else
}

_tmux-kill-session() {
  [[ -n ${tmux_describe} ]] && print "销毁指定会话" && return
  _arguments -s \
    '-a[杀死除 -t 指定的会话外的所有会话]' \
    '-t+[指定目标会话]:session:__tmux-sessions' \
    '-C[清除与会话关联的所有窗口中的警报（铃声、活动、静默）]'
}

_tmux-kill-window() {
  [[ -n ${tmux_describe} ]] && print "销毁指定窗口" && return
  _arguments -s \
    '-a[杀死除 -t 指定的窗口外的所有窗口]' \
    '-t+[指定目标窗口]:window:__tmux-windows'
}

_tmux-last-pane() {
  [[ -n ${tmux_describe} ]] && print "选择先前选中的窗格" && return
  _arguments -s \
    '-d[禁用窗格输入]' \
    '-e[启用窗格输入]' \
    '-Z[如果窗口已缩放则保持缩放]' \
    '-t+[指定会话]:session:__tmux-sessions'
}

_tmux-last-window() {
  [[ -n ${tmux_describe} ]] && print "选择先前选中的窗口" && return
  _arguments '-t+[指定会话]:session:__tmux-sessions'
}

_tmux-link-window() {
  [[ -n ${tmux_describe} ]] && print "将一个窗口链接到另一个" && return
  _arguments -s \
    '(-b)-a[将窗口移动到目标窗口之后的下一个索引]' \
    '(-a)-b[将窗口移动到目标窗口之前的下一个索引]' \
    "-d[不使新窗口成为活动窗口]" \
    '-k[如果目标窗口存在则杀死]' \
    '-s+[指定源窗口]:window:__tmux-windows' \
    '-t+[指定目标窗口]:window:__tmux-windows'
}

_tmux-list-buffers() {
  [[ -n ${tmux_describe} ]] && print "列出一个会话的粘贴缓冲区" && return
  _arguments \
    '-F+[指定输出格式]:format:__tmux-formats' \
    '-f+[过滤项目]:filter format:__tmux-formats'
}

_tmux-list-clients() {
  [[ -n ${tmux_describe} ]] && print "列出连接到服务器的客户端" && return
  _arguments -s \
    '-F+[指定输出格式]:format:__tmux-formats' \
    '-t+[指定会话]:session:__tmux-sessions'
}

_tmux-list-commands() {
  [[ -n ${tmux_describe} ]] && print "列出支持的子命令" && return
  _arguments '-F+[指定格式]:format:__tmux-formats' '1:sub-command:_tmux'
}

_tmux-list-keys() {
  [[ -n ${tmux_describe} ]] && print "列出所有键绑定" && return
  _arguments -s \
    '-1[仅列出第一个匹配的键]' \
    '-a[列出有注释的键的命令]' \
    '-N[仅列出带有注释的键]' \
    '-P+[指定在每个按键前打印的前缀]:prefix' \
    '-T+[指定键表]:key table'
