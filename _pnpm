_pnpm() {
  local curcontext="$curcontext" state state_descr line ret=1
  typeset -A opt_args

  _arguments -C \
    '(- *)'{-h,--help}'[显示帮助信息]' \
    '(- *)'{-v,--version}'[显示版本号]' \
    '(-r --recursive)'{-r,--recursive}'[在工作区的每个项目中运行]' \
    '(-C --dir)'{-C+,--dir=}'[切换到指定目录]:目录:_files -/' \
    '(-g --global)'{-g,--global}'[全局操作]' \
    '(-w --workspace-root)'{-w,--workspace-root}'[在工作区根目录运行]' \
    '--color[强制颜色输出]' \
    '--no-color[禁用颜色输出]' \
    '--loglevel[日志级别]:级别:(debug info warn error)' \
    '--reporter[输出格式]:格式:(default ndjson append-only)' \
    '--stream[实时流式输出，带包名前缀]' \
    '--aggregate-output[合并并行输出，任务结束后统一打印]' \
    '--use-stderr[输出到 stderr]' \
    '--filter[过滤器，选择匹配的包执行]:过滤表达式' \
    ':命令:->cmds' \
    '*::参数:->args'

  case "$state" in
    cmds)
      _describe -t commands "pnpm 命令" _pnpm_commands && ret=0
      ;;
    args)
      case "$words[1]" in
        add)
          _pnpm_add_options
          ;;
        install|i)
          _pnpm_install_options
          ;;
        remove|rm)
          _pnpm_remove_options
          ;;
        update|up)
          _pnpm_update_options
          ;;
        run|run-script)
          case "$state" in
            scripts) _pnpm_get_scripts ;;
            scriptargs) _normal ;;
          esac
          _pnpm_run_options
          ;;
        exec)
          _pnpm_exec_options
          ;;
        publish)
          _pnpm_publish_options
          ;;
        link|ln)
          _pnpm_link_options
          ;;
        unlink)
          _arguments -C -s '1:链接名'
          ;;
        list|ls)
          _pnpm_list_options
          ;;
        outdated)
          _arguments -C -s \
            '(-r --recursive)'{-r,--recursive}'[递归检查]' \
            '(-g --global)'{-g,--global}'[检查全局包]' \
            '(-C --dir)'{-C+,--dir=}'[指定目录]:目录:_files -/' \
            '--filter[过滤工作区包]:过滤器' \
            '--json[JSON 格式输出]' \
            '--long[-l]:详细信息' \
            '--no-optional[不检查 optionalDependencies]' \
            '--no-dev[不检查 devDependencies]'
          ;;
        why)
          _arguments -C -s \
            '(-r --recursive)'{-r,--recursive}'[递归显示]' \
            '--json[JSON 格式输出]' \
            '--parseable[机器可读输出]' \
            '1:包名'
          ;;
        audit)
          _arguments -C -s \
            '(-r --recursive)'{-r,--recursive}'[递归审计]' \
            '--json[JSON 格式输出]' \
            '--only-dev[只检查 devDependencies]' \
            '--only-prod[只检查 dependencies]' \
            '--ignore-registry-errors[忽略注册表错误]'
          ;;
        init)
          _arguments -C -s \
            '(-y --yes)'{-y,--yes}'[使用默认值初始化]' \
            '(-C --dir)'{-C+,--dir=}'[指定初始化目录]:目录:_files -/'
          ;;
        create)
          _arguments -C -s \
            '(-C --dir)'{-C+,--dir=}'[指定目录]:目录:_files -/' \
            '1:create 包名（如 vite next react）'
          ;;
        dlx)
          _arguments -C -s \
            '--package[-p]:指定要使用的包' \
            '(-w --workspace-root)'{-w,--workspace-root}'[在工作区根执行]' \
            '1:包名' \
            '*::参数:包参数'
          ;;
        config|c)
          _arguments -C -s \
            '(-g --global)'{-g,--global}'[全局配置]' \
            '--json[JSON 格式输出]' \
            '--location[配置位置]:位置:(project global)' \
            '1:config 子命令:->config_subcmd' \
            '*:键值'
          case "$state" in
            config_subcmd) _pnpm_config_subcmds ;;
          esac
          ;;
        store)
          _arguments -C -s \
            '1:store 子命令:->store_subcmd'
          case "$state" in
            store_subcmd) _pnpm_store_subcmds ;;
          esac
          ;;
        cache)
          _arguments -C -s \
            '1:cache 子命令:->cache_subcmd'
          case "$state" in
            cache_subcmd) _pnpm_cache_subcmds ;;
          esac
          ;;
        env)
          _arguments -C -s \
            '(-g --global)'{-g,--global}'[全局安装]' \
            '1:env 子命令:->env_subcmd' \
            '*:版本号'
          case "$state" in
            env_subcmd) _pnpm_env_cmds ;;
          esac
          ;;
        deploy)
          _arguments -C -s \
            '--filter[过滤工作区包]:过滤器' \
            '--prod[只部署生产依赖]' \
            '--no-optional[不包括 optionalDependencies]' \
            '1:输出目录:_files -/'
          ;;
        prune)
          _arguments -C -s \
            '--prod[只保留生产依赖]' \
            '--no-optional[移除 optionalDependencies]'
          ;;
        rebuild|rb)
          _arguments -C -s \
            '(-r --recursive)'{-r,--recursive}'[递归重编]' \
            '--store-dir[指定存储目录]:目录:_files -/' \
            "\*:包名"
          ;;
        pack)
          _arguments -C -s \
            '--dry-run[模拟打包]' \
            '--pack-destination[打包输出目录]:目录:_files -/' \
            '1:目录:_files -/'
          ;;
        start)
          _arguments -C -s \
            '(-r --recursive)'{-r,--recursive}'[递归运行]' \
            '--if-present[脚本未定义时不报错]' \
            '--filter[过滤工作区包]:过滤器'
          ;;
        test|t)
          _arguments -C -s \
            '(-r --recursive)'{-r,--recursive}'[递归运行]' \
            '--if-present[脚本未定义时不报错]' \
            '--filter[过滤工作区包]:过滤器'
          ;;
        install-test|it)
          _pnpm_install_options
          ;;
        fetch)
          _arguments -C -s \
            '--dev[同时拉取 devDependencies]' \
            '--prod[只拉取 dependencies]' \
            '--no-optional[不拉取 optionalDependencies]'
          ;;
        import)
          _arguments -C -s \
            '--lockfile-only[只导入 lockfile]'
          ;;
        dedupe)
          _arguments -C -s \
            '--check[只检查不执行]'
          ;;
        licenses)
          _arguments -C -s \
            '--json[JSON 格式输出]' \
            '--long[-l]:详细信息' \
            '--filter[过滤工作区包]:过滤器'
          ;;
        patch)
          _arguments -C -s \
            '--edit-dir[指定编辑目录]:目录:_files -/' \
            '1:包名'
          ;;
        patch-commit)
          _arguments -C -s \
            '1:补丁目录:_files -/' \
            '2:输出补丁文件:_files'
          ;;
        patch-remove)
          _arguments -C -s \
            '1:包名'
          ;;
        approve-builds)
          _arguments -C -s \
            '(-g --global)'{-g,--global}'[全局批准]' \
            "\*:包名"
          ;;
        ignored-builds)
          _arguments -C -s \
            '--json[JSON 格式输出]'
          ;;
        bin)
          _arguments -C -s \
            '1:包名'
          ;;
        doctor)
          _arguments -C -s \
            '--json[JSON 格式输出]'
          ;;
        root)
          ;;
        self-update)
          _arguments -C -s \
            '--version[更新到指定版本]:版本号'
          ;;
        recursive|rec)
          _arguments -C -s \
            '1:子命令:(add install remove update link unlink exec run outdate list)'
          ;;
        cat-file|cat-index)
          _arguments -C -s '1:哈希值'
          ;;
        find-hash)
          _arguments -C -s '1:哈希值'
          ;;
        *)
          ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

