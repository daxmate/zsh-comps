_pnpm_get_scripts() {
  local -a scripts
  if [[ -f package.json ]]; then
    scripts=($(jq -r '.scripts | keys[]' package.json 2>/dev/null))
  fi
  [[ ${#scripts} -gt 0 ]] && _describe -t scripts "脚本" scripts
}

