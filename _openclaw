#compdef openclaw

_openclaw_root_completion() {
  local -a commands
  local -a options
  
  _arguments -C \
    "(--version -V)"{--version,-V}"[输出版本号]" \
    "--container[在运行的 Podman/Docker 容器内运行 CLI]" \
    "--dev[开发模式：状态隔离到 ~/.openclaw-dev，默认端口 19001]" \
    "--profile[使用指定配置档（隔离状态到 ~/.openclaw-<name>）]" \
    "--log-level[全局日志级别覆盖（silent|fatal|error|warn|info|debug|trace）]" \
    "--no-color[禁用 ANSI 颜色]" \
    "1: :_values 'command' 'completion[生成 Shell 补全脚本]' 'setup[与 OpenClaw 对话；设置未完成时进入引导]' 'crestodian[已弃用：请使用 openclaw setup]' 'onboard[引导式设置（认证、模型、网关、工作区、频道和技能）]' 'configure[交互式配置（凭证、频道、网关和代理默认设置）]' 'config[非交互式配置管理（get/set/patch/unset/file/schema/validate）。不带子命令运行则进入引导式设置。]' 'backup[创建和验证备份存档及 SQLite 快照]' 'migrate[从其他代理系统导入状态]' 'doctor[诊断]' 'dashboard[使用当前令牌打开控制面板]' 'reset[重置本地配置/状态（保留 CLI 安装）]' 'uninstall[卸载服务]' 'message[发送、读取和管理消息及频道操作]' 'mcp[管理 OpenClaw mcp.servers 配置和频道桥接]' 'transcripts[检查存储的对话记录]' 'agent[通过网关运行一次代理对话（使用 --local 运行内嵌）]' 'agents[管理独立代理（工作区 + 认证 + 路由）]' 'audit[安全审计]' 'status[状态]' 'health[查看健康状态]' 'sessions[列出存储的对话会话]' 'commitments[列出和管理推断的后续承诺]' 'tasks[检查持久后台任务和 TaskFlow 状态]' 'acp[运行由网关支持的 ACP 桥接]' 'gateway[运行、检查和查询 WebSocket 网关]' 'daemon[管理网关服务（launchd/systemd/schtasks）]' 'logs[查看频道日志]' 'system[系统工具（事件、心跳、在线状态）]' 'models[模型发现、扫描和配置]' 'promos[发现并领取 ClawHub 的模型优惠]' 'infer[通过稳定 CLI 接口运行提供商推理命令]' 'capability[通过稳定 CLI 接口运行提供商推理命令]' 'approvals[管理执行审批（网关或节点主机）]' 'exec-approvals[管理执行审批（网关或节点主机）]' 'exec-policy[显示或同步执行策略与主机审批]' 'nodes[管理网关拥有的节点（配对、状态、调用和媒体）]' 'devices[设备配对和认证令牌]' 'node[运行和管理无头节点主机服务]' 'worker[运行受限云工作器运行时]' 'sandbox[管理沙箱容器（基于 Docker 的代理隔离）]' 'fleet[配置和管理隔离租户单元（实验性）]' 'worktrees[创建、检查、恢复和清理管理工作树]' 'attach[将 Claude Code 附加到网关会话（带限定 MCP 工具）]' 'tui[打开连接到网关的终端界面]' 'terminal[打开连接到网关的终端界面]' 'chat[对话]' 'cron[管理定时任务（通过网关）]' 'dns[DNS 辅助工具（Tailscale + CoreDNS）]' 'docs[搜索在线 OpenClaw 文档]' 'proxy[运行 OpenClaw 调试代理并检查捕获的流量]' 'hooks[管理内部代理钩子]' 'webhooks[Webhook 辅助工具和集成]' 'qr[生成移动端配对二维码和设置码]' 'clawbot[旧版 ClawBot 命令别名]' 'pairing[节点配对管理]' 'plugins[管理 OpenClaw 插件和扩展]' 'channels[频道桥接]' 'directory[查询联系人和群组 ID（自己、对等节点、群组）]' 'security[审计本地配置和状态中的常见安全问题]' 'secrets[密钥运行时控制]' 'skills[列出并检查可用技能]' 'update[更新插件]'" \
    "*::arg:->args"

  case $state in
    (args)
      case $line[1] in
        (completion) _openclaw_completion ;;
        (setup) _openclaw_setup ;;
        (crestodian) _openclaw_crestodian ;;
        (onboard) _openclaw_onboard ;;
        (configure) _openclaw_configure ;;
        (config) _openclaw_config ;;
        (backup) _openclaw_backup ;;
        (migrate) _openclaw_migrate ;;
