_openclaw_completion() {
  _arguments -C \
    "(--shell -s)"{--shell,-s}"[要生成补全的 Shell（默认：zsh）]" \
    "(--install -i)"{--install,-i}"[安装补全脚本到 Shell 配置文件中]" \
    "--write-state[写入补全脚本到 OPENCLAW_STATE_DIR/completions（不输出到 stdout）]" \
    "(--yes -y)"{--yes,-y}"[跳过确认（非交互）]"
}

