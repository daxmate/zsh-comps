#compdef cal ncal

local args

case $service in
  cal)
    args=(
      '-3[一行显示三个月]'
      '-m[周一作为每周第一天]'
    )
  ;;
  ncal)
    args=(
      '-J[显示儒略历]'
      '-e[显示西方复活节日期]'
      '-o[显示东正教复活节日期]'
      '-p[按 ncal 方式假定]'
      '-s[国家代码]'
      '-w[每列下方打印周数]'
    )
  ;;
esac

_arguments "${args[@]}" \
  '-j[显示儒略日]' \
  '-y[显示当前年份的日历]' \
  '::月' \
  ':年'
