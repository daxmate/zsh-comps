#compdef renice

if [[ $CURRENT = 2 ]]; then
  _message -e priority
else
  local opts ret=1
  opts=(
    '-g:将参数解释为进程组 ID'
    '-u:将参数解释为用户名'
    '-p:将参数解释为进程 ID'
  )
  _describe -o option opts && ret=0

  case ${(v)words[(I)-?]} in
    -g) _pgids && ret=0 ;;
    -u) _users && ret=0 ;;
    *)  _pids && ret=0;;
  esac
fi

return ret
