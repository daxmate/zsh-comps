    'subcommands::_describe -t subcommands "audit 子命令" _npm_audit_subcmds' \
    'options::_npm_options_for _npm_audit_options'
}

_npm_get_scripts() {
  local -a scripts
  if [[ -f package.json ]]; then
    scripts=($(jq -r '.scripts | keys[]' package.json 2>/dev/null))
  fi
  [[ ${#scripts} -gt 0 ]] && _describe -t scripts "脚本" scripts
}

