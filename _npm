#compdef npm

# npm Zsh 补全函数（动态版）
# 通过 npm 内置补全系统动态生成，始终与当前版本同步
#
# 安装到 fpath 后自动生效，无需额外配置
# 依赖于 npm 命令可用

_npm() {
  local si="$IFS"
  
  if (( $+commands[npm] )); then
    local IFS=$'\n'
    local -a reply
    reply=($(COMP_CWORD=$((CURRENT-1)) \
                 COMP_LINE="$BUFFER" \
                 COMP_POINT="$CURSOR" \
                 npm completion -- "${words[@]}" \
                 2>/dev/null))
    
    if (( $#reply )); then
      _describe 'npm 补全' reply
      IFS="$si"
      return 0
    fi
  fi
  
  # 回退：常见 npm 命令列表
  local -a cmds
  cmds=(
    'access:设置已发布包的访问级别'
    'adduser:添加注册表用户账户'
    'approve-scripts:批准特定依赖的安装脚本'
    'audit:运行安全审计'
    'bugs:在浏览器中查看包的 bug 报告'
    'cache:管理 npm 和 npx 缓存'
    'ci:执行干净的依赖安装（基于 lockfile）'
    'completion:生成 npm 的 tab 补全'
    'config:管理 npm 配置文件'
    'dedupe:减少包树中的重复'
    'deny-scripts:拒绝特定依赖的安装脚本'
    'deprecate:弃用某个包的版本'
    'diff:注册表差异比较'
    'dist-tag:修改包的分发标签'
    'docs:在浏览器中打开包文档'
    'doctor:检查 npm 环境健康状态'
    'edit:编辑已安装的包'
    'exec:从本地或远程 npm 包运行命令'
    'explain:解释已安装的包'
    'explore:浏览已安装的包'
    'find-dupes:查找包树中的重复'
    'fund:查找依赖项的资助信息'
    'get:获取 npm 配置值'
    'help:查看帮助信息'
    'help-search:搜索帮助文档'
    'init:创建 package.json 文件'
    'install:安装依赖包'
    'install-ci-test:执行 ci 后运行测试'
    'install-test:安装后运行测试'
    'link:创建符号链接以便本地开发'
    'll:列出已安装的包（详细信息）'
    'login:登录注册表'
    'logout:登出注册表'
    'ls:列出已安装的包'
    'org:管理组织成员'
    'outdated:检查过时的包'
    'owner:管理包所有者'
    'pack:创建包的 tarball'
    'ping:检查注册表连接'
    'pkg:管理 package.json'
    'prefix:显示前缀'
    'profile:更改注册表用户配置文件设置'
    'prune:移除无关的包'
    'publish:发布包'
    'query:使用 CSS 选择器查询包'
    'rebuild:重新编译包'
    'repo:在浏览器中打开包仓库'
    'restart:重启包'
    'root:显示 npm 根目录'
    'run:运行脚本'
    'sbom:生成软件物料清单（SBOM）'
    'search:搜索包'
    'set:设置配置值'
    'shrinkwrap:锁定依赖版本'
    'stage:暂存包'
    'star:收藏包'
    'stars:查看收藏的包'
    'start:启动包'
    'stop:停止包'
    'team:管理团队'
    'test:运行测试'
    'token:管理认证令牌'
    'trust:管理包信任设置'
    'undeprecate:取消弃用某个版本的包'
    'uninstall:卸载包'
    'unpublish:取消发布包'
    'unstar:取消收藏'
    'update:更新包'
    'version:显示版本'
    'view:查看包信息'
    'whoami:显示当前用户'
  )
  _describe 'npm 命令' cmds
  IFS="$si"
}

_npm "$@"
