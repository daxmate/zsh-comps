#compdef pdfcomp

_pdfcomp() {
  local -a options
  options=(
    '--screen[屏幕质量（最小体积）]'
    '--ebook[电子书质量]'
    '--ebook-plus[ebook 提升分辨率到 200 dpi ★ 默认]'
    '--printer[打印质量]'
    '--prepress[印前质量]'
    '--blackwhite[黑白转换（最小体积）]'
    {-h,--help}'[显示帮助]'
  )

  _arguments -s $options \
    '*:PDF 文件:_files -g "*.pdf(-.)"'
}

_pdfcomp
